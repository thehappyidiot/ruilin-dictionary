# Database (docker-compose defaults)
# Compose builds DB_URL for the app from these three values, so this is the single source of truth.
POSTGRES_DB="ruilin_dictionary"
POSTGRES_USER="ruilin_user"
POSTGRES_PASSWORD="change-me"

# Optional migration settings (only needed if you create new migrations with the goose CLI locally)
GOOSE_DRIVER="postgres"
GOOSE_MIGRATION_DIR="./internal/migrations/schema"

# Server config
PORT=8080
HOST_PORT=18080
IS_DEVELOPMENT=false
ADMIN_PASSWORD_HASH="$2a$12$replace-with-bcrypt-hash"
SESSION_SECRET="replace-with-at-least-32-random-characters"
# Optional (default 28800 = 8 hours)
SESSION_MAX_AGE_SECONDS=28800